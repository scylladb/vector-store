#!/bin/bash

set -e

repo=$(dirname "${BASH_SOURCE[0]}")
repo=$(realpath "$repo/..")

cd "$repo"
source scripts/_common.sh

total_steps=5
STEP_PREFIX="build "

step_header "Resolving version and verifying repository state"

if [[ -n $1 ]]; then
    vector_store_version=$1
    info "Version (override): $vector_store_version"
else
    vector_store_version=$(./scripts/run-with-release-toolchain cargo info vector-store | grep ^version: | cut -d ' ' -f 2)
    info "Version: $vector_store_version"
fi

if git status --porcelain | grep -q . ; then
    error "git repository is not clean. Dirty files:"
    git status --porcelain
    echo ""
    echo "Please commit or discard uncommitted changes before building a release."
    echo "To discard all changes: git checkout -- ."
    exit 1
fi
success "Repository is clean."

# Restore Cargo.toml and Cargo.lock from git if any build step fails.
restore_cargo_files() {
    git checkout -- Cargo.toml Cargo.lock 2>/dev/null && echo "  Restored Cargo.toml and Cargo.lock from git."
}
trap restore_cargo_files EXIT
trap 'echo ""; echo "  Interrupted."; exit 130' INT TERM

archs="amd64 arm64"

step_header "Building release binaries"

for arch in $archs ; do
    info "Building vector-store $vector_store_version for $arch..."
    RELEASE_VERSION=$vector_store_version TARGETARCH=$arch ./scripts/run-with-release-toolchain cargo clean --release
    RELEASE_VERSION=$vector_store_version TARGETARCH=$arch ./scripts/run-with-release-toolchain cargo build --release
    success "Built: target/$arch/release/vector-store"
done

step_header "Creating release archives"

for arch in $archs ; do
    vector_store_dir=vector-store-$vector_store_version-$arch
    vector_store_tarball=$vector_store_dir.tar.gz
    (cd target/$arch/release && tar -czf $vector_store_tarball --transform "s,^,$vector_store_dir/," vector-store)
    success "Created: target/$arch/release/$vector_store_tarball ($(du -h target/$arch/release/$vector_store_tarball | cut -f1))"
done

step_header "Generating Cargo SBOM"

mkdir -p SBOM
sed -i "s/version = \"0.0.0-dev\"/version = \"$vector_store_version\"/" Cargo.toml
cargo cyclonedx --manifest-path crates/vector-store/Cargo.toml --format json
restore_cargo_files
cargo_sbom=crates/vector-store/vector-store.cdx.json
[[ -f $cargo_sbom ]] || { error "SBOM was not generated at $cargo_sbom"; exit 1; }
mv $cargo_sbom SBOM/vector-store-$vector_store_version.cdx.json
success "Created: SBOM/vector-store-$vector_store_version.cdx.json"

step_header "Building Docker images and generating Docker SBOMs"

for arch in $archs ; do
    info "Building docker image for linux/$arch..."
    docker_tag=scylladb/vector-store:$vector_store_version-$arch
    docker build --platform linux/$arch --tag $docker_tag -f- . <<EOF
FROM redhat/ubi9-minimal
ARG TARGETARCH
RUN mkdir /opt/vector-store
COPY target/\$TARGETARCH/release/vector-store /opt/vector-store
CMD ["/opt/vector-store/vector-store"]
EOF
    success "Built: $docker_tag"

    info "Generating Docker SBOM for $arch..."
    docker_sbom=SBOM/vector-store-docker-$vector_store_version-$arch.cdx.json
    syft $docker_tag -o cyclonedx-json > $docker_sbom
    [[ -s $docker_sbom ]] || { error "Docker SBOM is empty at $docker_sbom"; exit 1; }
    success "Created: $docker_sbom"
done

echo ""
echo "${bold}${green}========================================"
echo " BUILD COMPLETE: vector-store $vector_store_version"
echo "========================================${reset}"
echo ""
echo "Artifacts:"
for arch in $archs ; do
    echo "  - target/$arch/release/vector-store-$vector_store_version-$arch.tar.gz"
done
echo "  - SBOM/vector-store-$vector_store_version.cdx.json"
for arch in $archs ; do
    echo "  - SBOM/vector-store-docker-$vector_store_version-$arch.cdx.json"
    echo "  - scylladb/vector-store:$vector_store_version-$arch (local docker image)"
done
echo ""
echo "Next step: run ./scripts/_upload-release $vector_store_version to publish."

# Success — disarm the trap.
trap - EXIT


