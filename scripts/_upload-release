#!/bin/bash

set -e

repo_dir=$(dirname "${BASH_SOURCE[0]}")
repo_dir=$(realpath "$repo_dir/..")

cd "$repo_dir"
source scripts/_common.sh

total_steps=3
STEP_PREFIX="upload "

step_header "Verifying prerequisites"

if [[ -n $1 ]]; then
    vector_store_version=$1
    info "Version (override): $vector_store_version"
else
    vector_store_version=$(./scripts/run-with-release-toolchain cargo info vector-store | grep ^version: | cut -d ' ' -f 2)
    info "Version: $vector_store_version"
fi
tag=$vector_store_version

git rev-parse "$tag" > /dev/null 2>&1 || { error "tag $tag does not exist"; exit 1; }
success "Tag $tag exists."

command -v gh > /dev/null 2>&1 || { error "gh cli is not installed (https://cli.github.com/)"; exit 1; }
success "gh CLI available."

command -v docker > /dev/null 2>&1 || { error "docker is not installed"; exit 1; }
docker buildx version > /dev/null 2>&1 || { error "docker buildx is not available"; exit 1; }
success "Docker and buildx available."

archs="amd64 arm64"

step_header "Collecting and uploading GitHub release assets"

assets=()

for arch in $archs ; do
    tarball=target/$arch/release/vector-store-$vector_store_version-$arch.tar.gz
    [[ -f $tarball ]] || { error "$tarball not found, run scripts/_build-release first"; exit 1; }
    assets+=("$tarball")
done

cargo_sbom=SBOM/vector-store-$vector_store_version.cdx.json
[[ -f $cargo_sbom ]] || { error "$cargo_sbom not found, run scripts/_build-release first"; exit 1; }
assets+=("$cargo_sbom")

for arch in $archs ; do
    docker_sbom=SBOM/vector-store-docker-$vector_store_version-$arch.cdx.json
    [[ -f $docker_sbom ]] || { error "$docker_sbom not found, run scripts/_build-release first"; exit 1; }
    assets+=("$docker_sbom")
done

info "Uploading ${#assets[@]} assets to release $tag:"
for asset in "${assets[@]}" ; do
    echo "    - $asset"
done

if gh release view "$tag" > /dev/null 2>&1; then
    info "Release $tag already exists, uploading assets."
    gh release upload "$tag" "${assets[@]}" --clobber
else
    info "Creating release $tag with auto-generated notes."
    gh release create "$tag" --generate-notes "${assets[@]}"
fi
success "Upload complete."

step_header "Pushing Docker images and manifest"

github_repo=$(git remote get-url origin | sed 's|.*github.com[:/]||;s|\.git$||')
if [[ $github_repo != "scylladb/vector-store" ]]; then
    echo "  Skipping Docker push (running from fork: $github_repo)."
    echo "  Local images are available for verification:"
    for arch in $archs ; do
        echo "    - scylladb/vector-store:$vector_store_version-$arch"
    done
else
    for arch in $archs ; do
        info "Pushing scylladb/vector-store:$vector_store_version-$arch..."
        docker push scylladb/vector-store:$vector_store_version-$arch
        success "Pushed: scylladb/vector-store:$vector_store_version-$arch"
    done

    echo ""
    info "Creating multi-platform Docker manifest..."
    docker_manifest=scylladb/vector-store:$vector_store_version
    docker buildx imagetools create -t $docker_manifest \
        scylladb/vector-store:$vector_store_version-amd64 \
        scylladb/vector-store:$vector_store_version-arm64
    success "Pushed manifest: $docker_manifest"
fi

echo ""
echo "${bold}${green}========================================"
echo " UPLOAD COMPLETE: vector-store $vector_store_version"
echo "========================================${reset}"
echo ""
echo "Published:"
echo "  - GitHub release: $tag (${#assets[@]} assets)"
if [[ $github_repo == "scylladb/vector-store" ]]; then
    for arch in $archs ; do
        echo "  - Docker Hub: scylladb/vector-store:$vector_store_version-$arch"
    done
    echo "  - Docker Hub: $docker_manifest (multi-platform manifest)"
else
    echo "  - Docker push skipped (fork: $github_repo)"
fi
